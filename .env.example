# Copy this file to `.env` (already gitignored) and fill in your real values.
# DO NOT commit the resulting `.env`. DO NOT paste the key into chat.
#
# After editing `.env`, load it once into your current shell:
#   source scripts/load_env.sh
# Then any subsequent python/.venv commands in the same shell will inherit the vars.

OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini

# OpenAI-compatible endpoint. Leave blank for the official OpenAI API.
# Set to your provider's base URL when using a compatible service:
#   智谱 GLM (BigModel):  https://open.bigmodel.cn/api/paas/v4
#   DeepSeek:             https://api.deepseek.com
#   Moonshot/Kimi:        https://api.moonshot.cn/v1
# OPENAI_BASE_URL=

# Optional defaults consumed by the pilot helper scripts.
PHASE5_LIMIT_ROWS=300
PHASE5_PROMPT_VERSION=v2_due_sbr
PHASE5_EMBEDDING_DIM=16
PHASE5_ALIGNED_CSV=data/aligned/aligned_customer_month_decoupled_env_full_d3c.csv
